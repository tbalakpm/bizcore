{
  "name": "bizcore-api",
  "version": "1.0.0",
  "description": "BizCore backend (Node + Express + SQLite + JWT + i18n)",
  "main": "dist/index.js",
  "type": "commonjs",
  "license": "MIT",
  "scripts": {
    "build": "rm -rf ./dist && tsc",
    "dev": "nodemon --watch src --ext ts,json --exec tsx src/index.ts",
    "start": "node index.js",
    "postbuild": "cp -R drizzle dist/drizzle && mkdir dist/.env && cp .env/.env.local dist/.env  && cp -R src/i18n dist/i18n && cp -R src/public dist/public && cp package.json dist/package.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "bcryptjs": "^3.0.3",
    "bwip-js": "^4.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pdfmake": "^0.3.7",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-elasticsearch": "^8.1.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "rotating-file-stream": "^3.2.9",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bwip-js": "^3.2.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/pdfmake": "^0.3.2",
    "drizzle-kit": "^0.31.10",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
