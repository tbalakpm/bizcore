{
  "name": "bizcore-api",
  "version": "1.0.0",
  "description": "BizCore backend (Node + Express + SQLite + JWT + i18n)",
  "main": "dist/index.js",
  "type": "commonjs",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --watch src --ext ts,json --exec tsx src/index.ts",
    "start": "node dist/index.js",
    "postbuild": "cp -R src/i18n dist/i18n && cp -R src/public dist/public && cp package.json dist/package.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "bcryptjs": "^3.0.3",
    "bwip-js": "^2.0.11",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pdfkit": "^0.17.2"
  },
  "devDependencies": {
    "@types/bwip-js": "^3.2.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.3",
    "@types/pdfkit": "^0.17.5",
    "drizzle-kit": "^0.31.9",
    "nodemon": "^3.1.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
