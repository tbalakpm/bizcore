### GET all products
GET {{baseUrl}}/products
Content-Type: application/json
Authorization: Bearer {{token}}

### GET product by id
GET {{baseUrl}}/products/1
Content-Type: application/json
Authorization: Bearer {{token}}

### POST create new product
POST {{baseUrl}}/products
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "code": "PROD001",
  "name": "Laptop",
  "description": "High-performance laptop for professionals",
  "categoryId": 1,
  "qtyPerUnit": "1 unit",
  "unitPrice": "999.99",
  "unitsInStock": 50,
  "isActive": true
}

### PUT update product by id
PUT {{baseUrl}}/products/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "code": "PROD001-V2",
  "name": "Laptop Pro",
  "description": "Updated high-performance laptop for professionals",
  "categoryId": 1,
  "qtyPerUnit": "1 unit",
  "unitPrice": "1299.99",
  "unitsInStock": 45,
  "isActive": true
}

### DELETE product by id
DELETE {{baseUrl}}/products/1
Content-Type: application/json
Authorization: Bearer {{token}}
